---
import BaseLayout from '@layouts/BaseLayout.astro';

export interface Props {
  title: string;
  description: string;
  author: string;
  publishedAt: Date;
  updatedAt?: Date;
  tags?: string[];
  relatedPosts?: Array<{ title: string; description: string; href: string }>;
  ogImage?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  author,
  publishedAt,
  updatedAt,
  tags = [],
  relatedPosts = [],
  ogImage,
  jsonLd,
} = Astro.props;

const dateFormatter = new Intl.DateTimeFormat('en', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  ogType="article"
  publishedAt={publishedAt}
  updatedAt={updatedAt}
  author={author}
  tags={tags}
  jsonLd={jsonLd}
>
  <article class="mx-auto max-w-3xl space-y-8">
    <header class="space-y-5 border-b border-gray-200 pb-8 dark:border-gray-700">
      <nav aria-label="Breadcrumb" class="text-sm text-gray-500 dark:text-gray-400">
        <a href={`${base}blog`} class="hover:text-blue-600 dark:hover:text-blue-400">Blog</a>
      </nav>

      <div class="flex flex-wrap gap-2">
        {tags.map((tag) => (
          <span class="rounded bg-blue-100 px-2 py-1 text-xs font-medium text-blue-800 dark:bg-blue-900 dark:text-blue-200">
            {tag}
          </span>
        ))}
      </div>

      <div class="space-y-4">
        <h1 class="text-4xl font-bold tracking-normal text-gray-900 dark:text-white">
          {title}
        </h1>
        <p class="text-xl leading-8 text-gray-600 dark:text-gray-300">
          {description}
        </p>
      </div>

      <p class="text-sm text-gray-500 dark:text-gray-400">
        By {author} | Published <time datetime={publishedAt.toISOString()}>{dateFormatter.format(publishedAt)}</time>
        {updatedAt && updatedAt.getTime() !== publishedAt.getTime() && (
          <> | Updated <time datetime={updatedAt.toISOString()}>{dateFormatter.format(updatedAt)}</time></>
        )}
      </p>
    </header>

    <div class="prose prose-gray max-w-none dark:prose-invert prose-pre:overflow-x-auto prose-a:text-blue-600 dark:prose-a:text-blue-400">
      <slot />
    </div>

    {relatedPosts.length > 0 && (
      <section class="space-y-4 border-t border-gray-200 pt-8 dark:border-gray-700" aria-labelledby="related-posts">
        <h2 id="related-posts" class="text-2xl font-bold text-gray-900 dark:text-white">Related Posts</h2>
        <div class="grid gap-4 sm:grid-cols-2">
          {relatedPosts.map((post) => (
            <a
              href={post.href}
              class="block rounded-lg border border-gray-200 bg-white p-4 transition-colors hover:border-blue-500 dark:border-gray-700 dark:bg-gray-800 dark:hover:border-blue-400"
            >
              <h3 class="font-semibold text-gray-900 dark:text-white">{post.title}</h3>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">{post.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>